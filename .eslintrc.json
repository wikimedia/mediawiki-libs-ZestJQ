{
	"root": true,
	"env": {
		"es2022": true,
		"node": true
	},
	"ignorePatterns": [
		"dist/",
		"lib/JQGrammar.js",
		"lib/JQBuiltin.js",
		"src/",
		"node_modules/",
		"tests/phpunit/",
		"vendor/"
	],
	"parserOptions": {
		"sourceType": "module"
	},
	"overrides": [
		{
			"files": [ "**/*.ts" ],
			"extends": [
				"wikimedia",
				"@wmde/eslint-config-wikimedia-typescript"
			]
		}
	]
}

{
	"name": "wikimedia/zest-jq",
	"description": "Implementation of 'jq' JSON-filter language",
	"keywords": [
		"jq",
		"json"
	],
	"license": "MIT",
	"support": {
		"source": "https://gerrit.wikimedia.org/r/mediawiki/libs/ZestJQ",
		"wiki": "https://www.mediawiki.org/wiki/ZestJQ"
	},
	"authors": [
		{
			"name": "C. Scott Ananian",
			"email": "cscott@cscott.net",
			"homepage": "https://cscott.net"
		}
	],
	"bin": [
		"tools/zestjq"
	],
	"autoload": {
		"psr-4": {
			"Wikimedia\\ZestJQ\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Wikimedia\\ZestJQ\\Tests\\": "tests/phpunit/"
		}
	},
	"require": {
		"php": ">=8.1",
		"wikimedia/wikipeg": "^6.1.1"
	},
	"require-dev": {
		"mediawiki/mediawiki-codesniffer": "51.0.0",
		"mediawiki/mediawiki-phan-config": "0.20.0",
		"mediawiki/minus-x": "2.0.1",
		"ockcyp/covers-validator": "1.7.0",
		"php-parallel-lint/php-console-highlighter": "1.0.0",
		"php-parallel-lint/php-parallel-lint": "1.4.0",
		"phpunit/phpunit": "10.5.63",
		"wikimedia/update-history": "^1.0.1"
	},
	"scripts": {
		"test": [
			"parallel-lint . --exclude vendor",
			"@phpunit",
			"covers-validator",
			"@phpcs",
			"@phan",
			"minus-x check ."
		],
		"test-with-node": [
			"@test",
			"fresh-node -- npm test"
		],
		"phan": "phan --allow-polyfill-parser",
		"phpcs": "phpcs -sp",
		"phpunit": "phpunit",
		"cover": "phpunit --coverage-html coverage",
		"fix": [
			"minus-x fix .",
			"fresh-node -- npm run lint:fix",
			"phpcbf"
		],
		"update-history": "update-history patch",
		"build": [
			"@regen-jq-parser",
			"@build-stdenv",
			"fresh-node -- npm run build"
		],
		"regen-jq-parser": [
			"@regen-jq-parser-php",
			"@regen-jq-parser-js"
		],
		"regen-jq-parser-php": "fresh-node -- npm install && fresh-node -- npm run regen-jq-parser-php",
		"regen-jq-parser-js": "fresh-node -- npm install && fresh-node -- npm run regen-jq-parser-js",
		"build-stdenv": [
			"php tools/build-stdenv.php",
			"minus-x fix . || true",
			"phpcbf || true",
			"fresh-node -- npm run build-stdenv"
		]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}

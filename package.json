{
	"type": "module",
	"files": [
		"dist/",
		"bin/zestjq.js"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"devDependencies": {
		"@rollup/plugin-node-resolve": "^16.0.0",
		"@rollup/plugin-terser": "^0.4.4",
		"@types/node": "^25.6.2",
		"@types/d3-time-format": "^4.0.3",
		"@typescript-eslint/eslint-plugin": "^7.8.0",
		"@typescript-eslint/parser": "^7.8.0",
		"@wmde/eslint-config-wikimedia-typescript": "^0.2.14",
		"eslint": "^8.57.1",
		"eslint-config-wikimedia": "0.32.4",
		"jsdoc": "4.0.5",
		"jsdoc-wmf-theme": "1.3.0",
		"typescript": "^5.8",
		"rollup": "^4.0.0",
		"vitest": "^3.1",
		"wikipeg": "git+https://gerrit.wikimedia.org/r/wikipeg#refs/changes/49/1287049/1"
	},
	"bin": {
		"zestjq": "./bin/zestjq.js"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json && cp lib/JQGrammar.js lib/JQGrammar.d.ts lib/JQBuiltin.js lib/JQBuiltin.d.ts dist/",
		"build:browser": "npm run build && rollup -c rollup.browser.config.mjs",
		"doc": "jsdoc -c jsdoc.json",
		"typecheck": "npx tsc --noEmit --skipLibCheck",
		"test": "vitest run && npm run lint && npm run typecheck",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"build-stdenv": "node tools/build-stdenv.js",
		"regen-jq-parser": "npm run regen-jq-parser-php && npm run regen-jq-parser-js",
		"regen-jq-parser-php": "node node_modules/wikipeg/bin/wikipeg --common-lang --class-name JQGrammar --php src/JQGrammar.peg src/JQGrammar.php",
		"regen-jq-parser-js": "node node_modules/wikipeg/bin/wikipeg --common-lang --esm src/JQGrammar.peg lib/JQGrammar.js"
	},
	"peerDependencies": {
		"d3-time-format": "^4.1.0"
	}
}
